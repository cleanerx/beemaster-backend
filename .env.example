# Beemaster Backend Environment Variables
# Copy to .dev.vars for local development

# LiteLLM Proxy URL (Railway/Fly.io)
LITELLM_URL=https://your-litellm.railway.app

# LiteLLM Master Key (set via: wrangler secret put)
LITELLM_MASTER_KEY=sk-beemaster-master-your-key-here

